{
    "name": "chromium-formatters",
    "version": "1.0.1",
    "description": "The same formatters used by Chrom(ium) DevTools' \"Pretty Print\" feature, extracted into a standalone module for use outside of it",
    "keywords": [
        "chromium",
        "devtools",
        "formatter",
        "pretty-print",
        "code-formatting"
    ],
    "type": "module",
    "devDependencies": {
        "bun": "^1.3.14",
        "chai": "^6.2.2",
        "mocha": "^11.7.6",
        "requirejs": "^2.3.8",
        "terser": "^5.48.0"
    },
    "homepage": "https://cyrilsli.github.io/chromium-formatters",
    "bugs": {
        "url": "https://github.com/CyrilSLi/chromium-formatters/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CyrilSLi/chromium-formatters.git"
    },
    "scripts": {
        "build": "bun build.js",
        "test": "NODE_OPTIONS='--experimental-transform-types' mocha 'tests/**/*.js' 'tests/**/*.cjs'",
        "prepublishOnly": "npm run build"
    },
    "license": "BSD-3-Clause",
    "author": "CyrilSLi",
    "main": "dist/main.esm.min.js"
}
